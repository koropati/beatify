# Database Configuration
# Format: mysql+pymysql://user:password@host:port/database
DATABASE_URL=mysql+pymysql://beatify_user:beatify123@localhost:3306/beatify_db

# Public origin used to build absolute media URLs (audio stream & cover images)
# returned to clients. No trailing slash. In production set to your API domain.
PUBLIC_BASE_URL=https://beatify-api.satriakode.com
